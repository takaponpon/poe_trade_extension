{
  "manifest_version": 3,
  "name": "PoE2 Trade Sidebar Extension",
  "version": "1.0.1",
  "description": "Path of Exile 2 Trade Site Sidebar Extension. Injects a premium customizable sidebar UI on the right side of the screen.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://jp.pathofexile.com/trade2/search/poe2/*",
        "https://www.pathofexile.com/trade2/search/poe2/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_end"
    },
    {
      "matches": [
        "https://poe.ninja/poe2/builds/*"
      ],
      "js": ["pako.min.js", "poe_ninja_content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://www.pathofexile.com/*",
    "https://jp.pathofexile.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "content.css",
        "poe_ninja_content.css",
        "stats_translation_map.json",
        "items_translation_map.json"
      ],
      "matches": [
        "https://jp.pathofexile.com/*",
        "https://www.pathofexile.com/*",
        "https://poe.ninja/*"
      ]
    }
  ]
}
